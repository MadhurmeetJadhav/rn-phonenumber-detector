{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "lib": ["ES2018"],
    "declaration": true,
    "outDir": "lib",
    "rootDir": "src",
    "strict": true,
    "jsx": "react",
    "moduleResolution": "node",
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib"]
}